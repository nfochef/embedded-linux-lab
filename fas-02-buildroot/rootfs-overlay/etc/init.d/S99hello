#!/bin/sh
#
# S99hello — runs the hello binary at boot, logs output to /var/log/hello.log
#

NAME=hello
DAEMON=/usr/bin/hello
LOGFILE=/var/log/hello.log

start() {
    printf "Starting %s: " "$NAME"
    mkdir -p /var/log
    {
        echo "$(date) — boot"
        $DAEMON
        echo ""
    } >> $LOGFILE 2>&1
    echo "OK"
}

stop() {
    printf "Stopping %s: " "$NAME"
    echo "OK"
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart|reload)
        stop
        start
        ;;
    *)
        echo "Usage: $0 {start|stop|restart}"
        exit 1
        ;;
esac

exit 0
